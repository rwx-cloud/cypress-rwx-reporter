{
  "name": "@rwx-cloud/cypress-rwx-reporter",
  "version": "1.0.0",
  "description": "A Cypress reporter that writes RWX v1 test results.",
  "homepage": "https://github.com/rwx-cloud/cypress-rwx-reporter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rwx-cloud/cypress-rwx-reporter.git"
  },
  "main": "index.js",
  "type": "commonjs",
  "files": [
    "index.js",
    "lib",
    "README.md"
  ],
  "scripts": {
